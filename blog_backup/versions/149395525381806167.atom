      &lt;li style=&quot;color: rgba(255, 255, 255, 0.8); font-family: Lato, sans-serif; font-size: 0.9rem; padding: 3px 0px;&quot;&gt;⑦ &amp;nbsp;Pacific Coast Highway — The Drive South&lt;/li&gt;
      &lt;li style=&quot;color: rgba(255, 255, 255, 0.8); font-family: Lato, sans-serif; font-size: 0.9rem; padding: 3px 0px;&quot;&gt;⑧ &amp;nbsp;Los Angeles — 3 Nights (Kimpton)&lt;/li&gt;
      &lt;li style=&quot;color: rgba(255, 255, 255, 0.8); font-family: Lato, sans-serif; font-size: 0.9rem; padding: 3px 0px;&quot;&gt;⑨ &amp;nbsp;San Diego — 2 Nights&lt;/li&gt;
