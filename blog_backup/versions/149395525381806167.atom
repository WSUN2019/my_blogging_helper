    <title>2026 - Summer Road Trip - California - 13 Days</title>
    <published>2026-04-21T22:51:16Z</published>
    <content type='html'>&lt;header style=&quot;background: 0% 0% repeat rgb(26, 38, 64); color: white; font-family: Lato, sans-serif; padding: 64px 24px 56px; text-align: center;&quot;&gt;

